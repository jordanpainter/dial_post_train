{
  "wandb": {
    "project": "sft-british",
    "entity": "jordanpainter",
    "api_key": "",
    "notebook_name": "sft-british",
    "log_model": "false"
  },
  "model": {
    "model_id": "surrey-nlp/gemma3_dialectal_cpt",
    "tokenizer_id": "google/gemma-3-4b-it",
    "base_model_id": "google/gemma-3-4b-it",
    "attn_implementation": "eager"
  },
  "data": {
    "hf_dataset": "jordanpainter/alignment-british-final",
    "hf_split": "train",
    "test_size": 0.1,
    "seed": 2,
    "output_dir": "/mnt/fast/nobackup/scratch4weeks/$USER/models/sft-gemma-cpt-british",
    "remove_columns": []
  },
  "trainer": {
    "do_train": true,
    "output_dir": "/mnt/fast/nobackup/scratch4weeks/$USER/cache/sft-gemma-cpt-british",
    "per_device_train_batch_size": 2,
    "per_device_eval_batch_size": 2,
    "gradient_accumulation_steps": 2,
    "gradient_checkpointing": true,
    "optim": "paged_adamw_8bit",
    "learning_rate": 2e-05,
    "max_length": 1024,
    "logging_strategy": "steps",
    "eval_strategy": "steps",
    "save_strategy": "steps",
    "eval_steps": 500,
    "save_steps": 500,
    "logging_steps": 50,
    "num_train_epochs": 3,
    "bf16": true,
    "overwrite_output_dir": true,
    "lr_scheduler_type": "cosine",
    "warmup_ratio": 0.05,
    "load_best_model_at_end": true,
    "report_to": "wandb",
    "run_name": "sft_gemma_cpt_british"
  }
}
