{
  "wandb": {
    "project": "sft-gemma-cpt",
    "entity": "YOUR_WANDB_ENTITY",
    "api_key": "",
    "notebook_name": "sft-gemma-cpt",
    "log_model": "checkpoint"
  },
  "model": {
    "model_id": "surrey-nlp/gemma3_dialectal_cpt",
    "tokenizer_id": "surrey-nlp/gemma3_dialectal_cpt"
  },
  "data": {
    "hf_dataset": "argilla/ultrafeedback-binarized-preferences",
    "hf_split": "train",
    "test_size": 0.1,
    "seed": 2,
    "output_dir": "/mnt/fast/nobackup/scratch4weeks/$USER/models/sft-gemma-cpt",
    "remove_columns": [
      "prompt",
      "chosen",
      "rejected",
      "chosen_rating",
      "rejected_rating",
      "chosen_model",
      "rejected_model",
      "source"
    ]
  },
  "trainer": {
    "do_train": true,
    "output_dir": "/mnt/fast/nobackup/scratch4weeks/$USER/cache/sft-gemma-cpt",
    "per_device_train_batch_size": 2,
    "per_device_eval_batch_size": 2,
    "gradient_accumulation_steps": 2,
    "gradient_checkpointing": true,
    "optim": "paged_adamw_8bit",
    "learning_rate": 2e-5,
    "max_length": 1024,
    "logging_strategy": "steps",
    "eval_strategy": "steps",
    "save_strategy": "steps",
    "eval_steps": 500,
    "save_steps": 500,
    "logging_steps": 50,
    "num_train_epochs": 3,
    "bf16": true,
    "overwrite_output_dir": true,
    "lr_scheduler_type": "cosine",
    "warmup_ratio": 0.05,
    "load_best_model_at_end": true,
    "report_to": "wandb",
    "run_name": "sft-gemma-cpt"
  }
}
