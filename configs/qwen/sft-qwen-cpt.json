{
  "wandb": {
    "project": "sft-qwen-cpt",
    "entity": "jordanpainter",
    "api_key": "",
    "notebook_name": "sft-qwen-cpt",
    "log_model": "checkpoint"
  },
  "model": {
    "model_id": "kadarsh22/galore_pretrained_qwen_64k",
    "tokenizer_id": "Qwen/Qwen3-8B",
    "base_model_id": "Qwen/Qwen3-8B-Instruct"
  },
  "data": {
    "hf_dataset": "argilla/ultrafeedback-binarized-preferences",
    "hf_split": "train",
    "test_size": 0.1,
    "seed": 2,
    "output_dir": "/mnt/fast/nobackup/scratch4weeks/$USER/models/sft-qwen-cpt",
    "remove_columns": [
      "instruction",
      "chosen_response",
      "rejected_response",
      "chosen_avg_rating",
      "rejected_avg_rating",
      "chosen_model",
      "source"
    ]
  },
  "trainer": {
    "do_train": true,
    "output_dir": "/mnt/fast/nobackup/scratch4weeks/$USER/cache/sft-qwen-cpt",
    "per_device_train_batch_size": 4,
    "per_device_eval_batch_size": 4,
    "gradient_accumulation_steps": 1,
    "gradient_checkpointing": true,
    "optim": "paged_adamw_8bit",
    "learning_rate": 2e-05,
    "max_length": 1024,
    "logging_strategy": "steps",
    "eval_strategy": "steps",
    "save_strategy": "steps",
    "eval_steps": 500,
    "save_steps": 500,
    "logging_steps": 50,
    "num_train_epochs": 3,
    "bf16": true,
    "overwrite_output_dir": true,
    "lr_scheduler_type": "cosine",
    "warmup_ratio": 0.05,
    "load_best_model_at_end": true,
    "report_to": "wandb",
    "run_name": "sft-qwen-cpt"
  }
}
